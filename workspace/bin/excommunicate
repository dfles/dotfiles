#!/usr/bin/env bash
#
# excommunicate — Reclaim the machine spirits consumed by a cogitated issue or sanction review.
#
# Kills the tmux session, removes the git worktree, and optionally
# deletes the branch.
#
# Usage:
#   excommunicate                       (auto-detects from current tmux session)
#   excommunicate <ISSUE-ID>            (e.g. excommunicate ENG-999999)
#   excommunicate <BRANCH>              (e.g. excommunicate dfles/eng-205-feature)
#
# Optional environment:
#   COGITATE_REPO    — Absolute path to the target repo

set -euo pipefail

# ── Colours ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── Output helpers ──────────────────────────────────────────────────────────────
rite()    { echo -e "${CYAN}${BOLD}  ⚙  RITE ${1}${NC}"; }
litany()  { echo -e "${DIM}     › ${1}${NC}"; }
blessed() { echo -e "${GREEN}  ✦  ${1}${NC}"; }
heresy()  { echo -e "${RED}${BOLD}  ✗  HERESY DETECTED: ${1}${NC}" >&2; exit 1; }
warning() { echo -e "${YELLOW}  ~  ${1}${NC}"; }

echo ""
echo -e "${BOLD}${RED}  ╔══════════════════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}${RED}  ║      E X C O M M U N I C A T I O N   R I T E             ║${NC}"
echo -e "${BOLD}${RED}  ║              Cleanse. Purify. Reclaim.                   ║${NC}"
echo -e "${BOLD}${RED}  ╚══════════════════════════════════════════════════════════╝${NC}"
echo ""

TARGET="${1:-}"

REPO="${COGITATE_REPO:-}"
[[ -z "$REPO" ]] && heresy "COGITATE_REPO not set. Export the absolute path to your target repo."
[[ -d "$REPO/.git" ]] || heresy "Reliquary not found at ${REPO}. Verify COGITATE_REPO is correct."

WORKTREES_DIR="${REPO}/.worktrees"

SELF_DESTRUCT=false

# If no args, detect from current tmux session
if [[ -z "$TARGET" ]]; then
    [[ -z "${TMUX:-}" ]] && heresy "No target provided and not inside tmux.\n     Usage: excommunicate [<ISSUE-ID|BRANCH>]"
    CURRENT_SESSION=$(tmux display-message -p '#S')
    # Only auto-detect sessions that match our naming patterns
    if [[ -d "${WORKTREES_DIR}/${CURRENT_SESSION}" ]]; then
        litany "Auto-detected session: ${CURRENT_SESSION}"
        CANDIDATES=("$CURRENT_SESSION")
        SELF_DESTRUCT=true
    else
        heresy "Current session '${CURRENT_SESSION}' does not appear to be a cogitate or sanction session."
    fi
else
    SANITIZED=$(echo "$TARGET" | tr '[:upper:]' '[:lower:]' | tr '/' '-')

    # Resolve which session(s) exist — issue workflow, review workflow, or both
    CANDIDATES=()
    tmux has-session -t "$SANITIZED" 2>/dev/null            && CANDIDATES+=("$SANITIZED")
    tmux has-session -t "review-${SANITIZED}" 2>/dev/null   && CANDIDATES+=("review-${SANITIZED}")
    [[ -d "${WORKTREES_DIR}/${SANITIZED}" ]]                 && [[ ! " ${CANDIDATES[*]} " =~ " ${SANITIZED} " ]]          && CANDIDATES+=("$SANITIZED")
    [[ -d "${WORKTREES_DIR}/review-${SANITIZED}" ]]          && [[ ! " ${CANDIDATES[*]} " =~ " review-${SANITIZED} " ]]   && CANDIDATES+=("review-${SANITIZED}")

    # Default to direct match if nothing found, so warnings print sensibly
    [[ ${#CANDIDATES[@]} -eq 0 ]] && CANDIDATES+=("$SANITIZED")
fi

for SESSION_NAME in "${CANDIDATES[@]}"; do
    litany "Processing: ${SESSION_NAME}"

    # ── Rite I: Silence the Tmux Congregation ────────────────────────────────
    rite "I — Silencing the Tmux Congregation"

    if [[ "$SELF_DESTRUCT" == true ]]; then
        litany "Session kill deferred — we're inside it."
    elif tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
        tmux kill-session -t "$SESSION_NAME"
        blessed "Session '${SESSION_NAME}' dissolved."
    else
        warning "No session '${SESSION_NAME}' found — already silent."
    fi

    # ── Rite II: Excising the Worktree ───────────────────────────────────────
    rite "II — Excising the Worktree"

    WORKTREE_PATH=$(find "$WORKTREES_DIR" -maxdepth 1 -type d -name "${SESSION_NAME}*" 2>/dev/null | head -1)

    if [[ -z "$WORKTREE_PATH" ]]; then
        warning "No worktree found matching '${SESSION_NAME}*' — already excised."
    else
        BRANCH_NAME=$(basename "$WORKTREE_PATH")
        litany "Removing worktree: ${WORKTREE_PATH}"
        cd "$REPO"
        git worktree remove "$WORKTREE_PATH" --force 2>/dev/null || true
        git worktree prune 2>/dev/null || true
        blessed "Worktree excised."

        # ── Rite III: Optionally Delete the Branch ───────────────────────────
        rite "III — Branch Disposal"

        if git show-ref --verify --quiet "refs/heads/${BRANCH_NAME}"; then
            echo -e "${YELLOW}  Delete branch '${BRANCH_NAME}'? [y/N]${NC} \c"
            read -r CONFIRM
            if [[ "$CONFIRM" == "y" || "$CONFIRM" == "Y" ]]; then
                git branch -D "$BRANCH_NAME"
                blessed "Branch '${BRANCH_NAME}' deleted."
            else
                warning "Branch preserved. The Machine Spirit lingers."
            fi
        fi
    fi
done

echo ""
echo -e "${GREEN}${BOLD}  ╔══════════════════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}${BOLD}  ║   THE PURGE IS COMPLETE. THE OMNISSIAH IS APPEASED.      ║${NC}"
echo -e "${GREEN}${BOLD}  ╚══════════════════════════════════════════════════════════╝${NC}"
echo ""

# Kill our own session last — tmux will switch us to the next available session
if [[ "$SELF_DESTRUCT" == true ]]; then
    sleep 1
    tmux kill-session -t "$CURRENT_SESSION"
fi
